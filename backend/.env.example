# ── LLM ──────────────────────────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to use the Claude API directly with your own key.
# If set, this takes priority and EMERGENT_LLM_KEY is ignored.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model (defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Fallback proxy key (only used when ANTHROPIC_API_KEY is not set)
EMERGENT_LLM_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=beastlyforge

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
SENDER_EMAIL=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
